APP_NAME=Trackify
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.trackify.vision2co.de
APP_TIMEZONE=Europe/Berlin

APP_LOCALE=de
APP_FALLBACK_LOCALE=de

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=sqlite
# SQLite file lives inside the Docker volume — do NOT change this path
DB_DATABASE=/var/www/html/database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

SANCTUM_STATEFUL_DOMAINS=api.trackify.vision2co.de
