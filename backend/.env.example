APP_NAME=Trackify
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://trackify-api.vision2co.de
APP_TIMEZONE=Europe/Berlin

APP_LOCALE=de
APP_FALLBACK_LOCALE=de

# Audience of the Sign in with Apple identity token (the iOS app's bundle identifier).
APPLE_CLIENT_ID=app.trackify.ios

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=sqlite
# SQLite file lives inside the Docker volume — do NOT change this path
DB_DATABASE=/var/www/html/database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120

FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=file

SANCTUM_STATEFUL_DOMAINS=trackify-api.vision2co.de
